{
  "name": "@celsowm/iridium-sql-client",
  "version": "0.1.5",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/celsowm/iridium-sql.git",
    "directory": "packages/iridium-client"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:types": "tsc -p tsconfig.json",
    "copy:wasm": "node scripts/copy-wasm.mjs",
    "build": "npm run build:wasm && npm run build:types && npm run copy:wasm",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
